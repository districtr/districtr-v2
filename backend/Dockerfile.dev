# Use official Python image inclusive of gcc pre-requisites.
# Pinned to a specific patch version for reproducible dev builds; upgrade
# intentionally by bumping this tag. For prod images, consider pinning to an
# image digest (python:3.12.7@sha256:...) to defend against tag-drift in supply
# chain attacks.
FROM python:3.12.7

# Set working directory inside the container
WORKDIR /districtr-backend

# Install PostGIS extension, PostgreSQL client, and GDAL
RUN apt-get update && apt-get install -y \
    git \
    postgresql-client \
    libpq-dev \
    gdal-bin \
    libgdal-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements file first and install dependencies
COPY requirements.txt .

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Copy the rest of the backend code into the container
COPY . .

# Command to run the server
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--reload"]
